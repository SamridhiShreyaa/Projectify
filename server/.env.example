# ── Backend server (Node/Express) ──────────────────────────────
# Copy to server/.env and fill in your own values.

# Port the API server listens on (default: 5000)
PORT=5000

# MongoDB connection string (local or Atlas)
# e.g. mongodb://localhost:27017/projectify
#   or mongodb+srv://<user>:<password>@<cluster>/projectify
MONGO_URI=

# Secret used to sign JWTs — use a long random string
JWT_SECRET=

# URL of the FastAPI AI service
AI_SERVICE_URL=http://localhost:8001

# Comma-separated CORS allowlist (optional; defaults to http://localhost:3000)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-client.example.com
