# ── AI service (FastAPI) ───────────────────────────────────────
# Copy to ai_service/.env and fill in your own values.
# Leave the API key blank to run in mock/heuristic mode (no LLM calls) —
# useful for local development, CI, and tests.

# LLM API key. Either variable works; OPENROUTER_API_KEY takes precedence.
OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# LLM base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional GitHub token — lifts the repo-review/verify API cap from 60 to
# 5000 requests/hour. Leave blank to use unauthenticated GitHub access.
# GITHUB_TOKEN=

# Comma-separated CORS allowlist (optional; defaults to *)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-client.example.com

# Rate limiting (optional; defaults to 5 requests per 60s)
# RATE_LIMIT_MAX=5
# RATE_LIMIT_WINDOW=60

# Chroma persistence directory for the RAG corpus (optional)
# CHROMA_DIR=.chroma
