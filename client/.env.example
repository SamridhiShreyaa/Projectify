# ── Client (React/Vite) ────────────────────────────────────────
# Copy to client/.env for local dev, or set in your host's build env.
# Vite bakes this in at build time, so it must be set before `npm run build`.

# Origin of the backend API server (no trailing slash).
# Local dev default is http://localhost:5000
VITE_API_URL=http://localhost:5000
